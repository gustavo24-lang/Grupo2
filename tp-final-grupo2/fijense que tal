
def definir_y_validar_texto(mensaje, error, min, max):
    variable = input(mensaje).lower()
    while len(variable) > max or len(variable) < min:
        print(error)
        variable = input(mensaje).lower()
    return(variable)


def  definir_y_validar_int(mensaje, error, min, max):
    variable = int(input(mensaje))
    while variable > max or variable < min:
        print(error)
        variable = int(input(mensaje))
    return(variable)

def pedir_opcion(mensaje, minimo, maximo):
    valor = int(input(mensaje))
    while valor < minimo or valor> maximo:
        print("ERROR- ingrese un numero entre ", minimo, "y", maximo)
        valor = int(input(mensaje))
    return valor

