def burbujeo(matriz):
    """aca ordena la matriz de MAYOR a MENOR segun la columna 2 cantidad vendida."""
    n = len(matriz)
    for i in range(n - 1):
        for j in range(n - 1 - i):
            if matriz[j][2] < matriz[j + 1][2]:
                aux            = matriz[j]
                matriz[j]      = matriz[j + 1]
                matriz[j + 1]  = aux
